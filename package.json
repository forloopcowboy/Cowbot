{
  "name": "investment-plan",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "nx": "nx",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "serve:api": "nx run api:serve",
    "serve:web": "nx run web:serve",
    "serve:desktop": "nx run desktop:dev",
    "serve:all": "nx run-many -t serve -p api,web",
    "serve:all:desktop": "nx run-many -t serve -p api,desktop",
    "db:up": "docker compose up -d postgres supertokens",
    "db:down": "docker compose down",
    "db:migrate": "nx run api:migrate",
    "db:codegen": "nx run api:codegen",
    "deploy:ssh": "bash scripts/deploy-ssh.sh",
    "deploy:ssh:web": "bash scripts/deploy-ssh.sh --only web",
    "deploy:ssh:api": "bash scripts/deploy-ssh.sh --only api",
    "deploy:ssh:caddy": "bash scripts/deploy-ssh.sh --only caddy",
    "publish:mac": "bash scripts/publish-mac.sh"
  },
  "devDependencies": {
    "@nx/eslint": "22.7.2",
    "@nx/eslint-plugin": "22.7.2",
    "@nx/js": "22.7.2",
    "@nx/nest": "22.7.2",
    "@nx/node": "22.7.2",
    "@nx/react": "22.7.2",
    "@nx/vite": "22.7.2",
    "@nx/vitest": "22.7.2",
    "@nx/web": "22.7.2",
    "@nx/workspace": "22.7.2",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.21",
    "@types/node": "^20.11.0",
    "jiti": "2.4.2",
    "nx": "22.7.2",
    "prettier": "^3.3.3",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "ws@>=8.0.0 <8.20.1": "^8.20.1",
    "yaml@>=2.0.0 <2.8.3": "^2.8.3",
    "brace-expansion@>=5.0.0 <5.0.6": "^5.0.6"
  },
  "dependencies": {}
}
