# Copy this file to deploy/.env on the VM and fill in real values.
# `deploy/.env` is .gitignored — do not commit it.

# ----- public hostnames ------------------------------------------------------
# These are the three subdomains served by Caddy. They must all resolve to the
# VM's public IP (see DEPLOYMENT.md for DNS instructions).
WEB_HOST=invest.example.com
API_HOST=api.invest.example.com
AUTH_HOST=auth.invest.example.com

# Leading dot is required — this lets the SuperTokens cookie issued by AUTH_HOST
# be sent back from WEB_HOST and API_HOST.
COOKIE_DOMAIN=.invest.example.com

# Used by Let's Encrypt for ACME registration / expiry notices.
ACME_EMAIL=you@example.com

# ----- Postgres -------------------------------------------------------------
POSTGRES_USER=investment
POSTGRES_PASSWORD=CHANGE_ME_to_a_long_random_string
POSTGRES_DB=investment_plan

# ----- SuperTokens ----------------------------------------------------------
# Shared between the SuperTokens core container and the API. Any random string
# of >=20 chars. Generate one with: `openssl rand -hex 32`.
SUPERTOKENS_API_KEY=CHANGE_ME_openssl_rand_hex_32

# ----- API secrets ----------------------------------------------------------
# 32-byte key (hex-encoded) used to encrypt user-supplied Anthropic API keys at
# rest. Generate with: `openssl rand -hex 32`. Rotating this invalidates any
# stored keys, so users will need to re-enter them.
API_KEY_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# ----- Downloads ------------------------------------------------------------
# Public URL of the macOS DMG, baked into the SPA at web build time.
# Auto-populated by `npm run publish:mac <user@host>` which uploads the .dmg
# to deploy/downloads/ on the VM and rewrites this line to the live URL.
# Leave unset to fall back to the relative path /downloads/cowboy-investor-mac.dmg.
DOWNLOAD_URL_MAC=
