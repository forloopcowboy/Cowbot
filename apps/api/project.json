{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/api/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "npm run build", "cwd": "apps/api" }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": { "command": "npm run start:dev", "cwd": "apps/api" }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": { "command": "npm run start", "cwd": "apps/api" }
    },
    "migrate": {
      "executor": "nx:run-commands",
      "options": { "command": "npm run migrate", "cwd": "apps/api" }
    },
    "codegen": {
      "executor": "nx:run-commands",
      "options": { "command": "npm run codegen", "cwd": "apps/api" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "npm test", "cwd": "apps/api" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "npm run lint", "cwd": "apps/api" }
    }
  },
  "tags": ["scope:api", "type:app"]
}
