{
  "name": "@investment-plan/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "codegen": "kysely-codegen --dialect=postgres --out-file=src/db/schema.generated.ts",
    "migrate": "docker compose -f ../../docker-compose.yml --profile migrate run --rm liquibase",
    "migrate:status": "docker compose -f ../../docker-compose.yml --profile migrate run --rm liquibase --changeLogFile=master.xml --url=jdbc:postgresql://postgres:5432/investment_plan --username=investment --password=investment status --verbose",
    "test": "jest --passWithNoTests",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/swagger": "^11.4.3",
    "@investment-plan/shared": "*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "kysely": "^0.28.17",
    "papaparse": "^5.4.1",
    "pg": "^8.13.0",
    "puppeteer": "^23.0.0",
    "marked": "^14.1.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "supertokens-node": "^24.0.2",
    "js-yaml": "^4.1.0",
    "yahoo-finance2": "^3.14.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.21",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/js-yaml": "^4.0.9",
    "@types/papaparse": "^5.3.15",
    "@types/pg": "^8.11.10",
    "jest": "^29.7.0",
    "kysely-codegen": "^0.20.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.6.3"
  }
}
